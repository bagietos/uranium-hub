# .gitignore for Uranium Hub

# Operating System Files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE and Editor Files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.netrwhist
.vim/

# OS-specific
.env.local
.env.*.local

# Lua/Roblox specific
*.luau.bak
*.lua.bak
*.swp

# Temporary files
*.tmp
*.temp
*.bak
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
desktop.ini

# Python
__pycache__/
*.py[cod]
*$py.class

# Build outputs (if any)
dist/
build/
*.egg-info/

# Node modules (if any)
node_modules/

# Logs
*.log
npm-debug.log*

# Misc
.env
.env.local
